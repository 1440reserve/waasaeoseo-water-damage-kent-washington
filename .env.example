# Which client to build/serve. Must match a folder name under clients/.
# Locally this defaults to kent if unset. On Vercel, set this per project.
SITE_ID=kent

# Lead form email delivery (https://resend.com). Required in production.
RESEND_API_KEY=

# The verified sender address leads are sent FROM (must be a Resend-verified domain you own).
LEAD_FROM_EMAIL=leads@youragency.com

# Optional: BCC every lead to your agency inbox for monitoring/QA.
LEAD_BCC_EMAIL=

# Optional: POST every lead as JSON to this URL (Zapier / GoHighLevel / HubSpot / Sheets webhook).
LEAD_WEBHOOK_URL=
